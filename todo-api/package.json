{
  "name": "todo-api",
  "version": "1.0.0",
  "description": "Todo API built with Fastify.",
  "main": "src/server.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "NODE_OPTIONS='--import tsx' vitest run",
    "test:watch": "NODE_OPTIONS='--import tsx' vitest",
    "test:coverage": "NODE_OPTIONS='--import tsx' vitest run --coverage",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build:ts": "tsc"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "fastify-tsconfig": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.9"
  }
}
